{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    // enabling these locally to catch unused vars while learning the codebase
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    // helpful for tracing async errors while debugging
    "preserveConstEnums": true,
    // makes it easier to follow control flow while stepping through in the debugger
    "inlineSources": true,
    // strictPropertyInitialization caught several bugs for me while reading through the auth module
    "strictPropertyInitialization": true,
    // enabling exactOptionalPropertyTypes to better understand how optional props are used throughout
    "exactOptionalPropertyTypes": true,
    // enabling verbatimModuleSyntax to get clearer import/export errors when studying module boundaries
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"],
  // keep test files in compilation for local experimentation
  "exclude": ["node_modules", "dist"]
}
